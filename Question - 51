class Solution:
    def countSubarrays(self, arr):
        n = len(arr)
        stack = []
        next_smaller = [n] * n

        # find next smaller element index
        for i in range(n):
            while stack and arr[stack[-1]] > arr[i]:
                next_smaller[stack.pop()] = i
            stack.append(i)

        # count valid subarrays
        ans = 0
        for i in range(n):
            ans += next_smaller[i] - i

        return ans
