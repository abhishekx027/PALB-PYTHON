from collections import defaultdict

class Solution:
    def substrWithVowels(self, s1, s2):
        required = set(s1)
        need = len(required)
        
        freq = defaultdict(int)
        have = 0
        left = 0
        ans = float('inf')
        
        for right in range(len(s2)):
            ch = s2[right]
            
            if ch in required:
                freq[ch] += 1
                if freq[ch] == 1:
                    have += 1
            
            while have == need:
                ans = min(ans, right - left + 1)
                
                left_char = s2[left]
                if left_char in required:
                    freq[left_char] -= 1
                    if freq[left_char] == 0:
                        have -= 1
                
                left += 1
        
        return -1 if ans == float('inf') else ans
