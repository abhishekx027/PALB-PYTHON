class Solution:
    def maxPeople(self, arr):
        n = len(arr)

        # next greater or equal to left
        left_block = [-1] * n
        stack = []

        for i in range(n):
            while stack and arr[stack[-1]] < arr[i]:
                stack.pop()
            left_block[i] = stack[-1] if stack else -1
            stack.append(i)

        # next greater or equal to right
        right_block = [n] * n
        stack = []

        for i in range(n - 1, -1, -1):
            while stack and arr[stack[-1]] < arr[i]:
                stack.pop()
            right_block[i] = stack[-1] if stack else n
            stack.append(i)

        ans = 1

        for i in range(n):
            # visible range limited by blockers
            cnt = right_block[i] - left_block[i] - 1
            ans = max(ans, cnt)

        return ans
