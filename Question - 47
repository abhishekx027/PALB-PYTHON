import heapq

class Solution:
    def minOperations(self, arr):

        total = sum(arr)
        target = total / 2

        # Max heap using negative values
        heap = [-x for x in arr]
        heapq.heapify(heap)

        operations = 0

        while total > target:

            x = -heapq.heappop(heap)

            half = x / 2

            total -= half

            heapq.heappush(heap, -half)

            operations += 1

        return operations
