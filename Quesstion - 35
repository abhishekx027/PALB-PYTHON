class Solution:
    def groupAnagrams(self, strs: List[str]) -> List[List[str]]:
        
        groups = {}
        
        for word in strs:
            key = ''.join(sorted(word))
            
            if key not in groups:
                groups[key] = []
            
            groups[key].append(word)
        
        result = list(groups.values())
        
        for group in result:
            group.sort()
        
        result.sort()
        
        return result
