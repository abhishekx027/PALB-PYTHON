class Solution:
    def getMinDiff(self, arr, k):
        n = len(arr)
        arr.sort()
        
        ans = arr[n-1] - arr[0]  # initial difference
        
        for i in range(n - 1):
            
            # smallest possible height
            small = min(arr[0] + k, arr[i+1] - k)
            
            # largest possible height
            big = max(arr[i] + k, arr[n-1] - k)
            
            # skip if negative
            if small < 0:
                continue
            
            ans = min(ans, big - small)
        
        return ans
